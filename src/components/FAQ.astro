---
const faqs = [
  ["Is FlowPilot free to start?", "Yes. You can start with curated resources and upgrade when your workflow grows."],
  ["Can I use my own domain?", "FlowPilot is designed to support polished creator systems and branded workflows."],
  ["How does tracking work?", "The dashboard helps organize discovery, saves, traffic, and performance signals."],
  ["Can I export my data?", "Your workflow data is structured so it can move with your operating system."],
  ["What payment methods do you accept?", "Standard SaaS billing options are supported for paid plans."],
  ["Is there a refund policy?", "Plans are designed to be simple and transparent for creator teams." ]
];
---

<section id="faq" class="px-5 py-20 sm:px-8 lg:px-10 lg:py-28">
  <div class="mx-auto max-w-5xl">
    <div class="mx-auto mb-12 max-w-3xl text-center">
      <p class="mb-3 text-sm font-extrabold uppercase tracking-[0.16em] text-[#6D5DFC]">FAQ</p>
      <h2 class="text-3xl font-extrabold tracking-[-0.055em] text-[#17142A] sm:text-5xl">Frequently asked questions</h2>
    </div>

    <div class="space-y-4">
      {faqs.map(([question, answer], index) => (
        <div data-faq-item class="overflow-hidden rounded-2xl border border-[#E8E5F8] bg-white shadow-[0_14px_40px_rgba(79,65,130,0.06)] transition-all duration-300 ease-out">
          <button
            type="button"
            data-faq-trigger
            class="flex w-full items-center justify-between gap-4 px-5 py-5 text-left text-sm font-extrabold text-[#17142A] transition hover:bg-[#FBFAFF] focus:outline-none focus:ring-4 focus:ring-[#8B7CFF]/15"
            aria-expanded="false"
            aria-controls={`faq-panel-${index}`}
          >
            <span>{question}</span>
            <span data-faq-icon class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#F1EEFF] text-lg leading-none text-[#8B7CFF] transition-transform duration-300 ease-out">+</span>
          </button>

          <div
            id={`faq-panel-${index}`}
            data-faq-panel
            class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out"
          >
            <div class="overflow-hidden">
              <p class="px-5 pb-5 text-sm leading-6 text-[#756F86]">{answer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const faqItems = Array.from(document.querySelectorAll('[data-faq-item]'));

    const setItemOpen = (item, isOpen) => {
      const trigger = item.querySelector('[data-faq-trigger]');
      const panel = item.querySelector('[data-faq-panel]');
      const icon = item.querySelector('[data-faq-icon]');

      trigger?.setAttribute('aria-expanded', String(isOpen));
      panel?.classList.toggle('grid-rows-[1fr]', isOpen);
      panel?.classList.toggle('grid-rows-[0fr]', !isOpen);
      icon?.classList.toggle('rotate-45', isOpen);
      item.classList.toggle('border-[#CFC8FF]', isOpen);
      item.classList.toggle('shadow-[0_18px_48px_rgba(109,93,252,0.10)]', isOpen);
    };

    faqItems.forEach(item => {
      const trigger = item.querySelector('[data-faq-trigger]');

      trigger?.addEventListener('click', () => {
        const shouldOpen = trigger.getAttribute('aria-expanded') !== 'true';

        faqItems.forEach(otherItem => setItemOpen(otherItem, false));
        setItemOpen(item, shouldOpen);
      });
    });
  })();
</script>
