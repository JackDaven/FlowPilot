---
import { toolsRegistry } from "../../lib/tools/registry";

const tools = toolsRegistry.map((tool) => ({
  id: tool.id,
  icon:
    tool.id === "morse"
      ? "·−"
      : tool.id === "js-tools"
        ? "JS"
        : tool.label.charAt(0).toUpperCase(),
  name: tool.name,
  description: tool.intro
}));
---

<div id="tools-panel-root" class="pointer-events-none fixed inset-0 z-[80]" aria-hidden="true">
  <div data-tools-backdrop class="absolute inset-0 bg-[#151326]/0 backdrop-blur-0 transition-all duration-300 ease-out"></div>

  <aside
    id="tools-panel"
    class="absolute right-0 top-0 z-[90] flex h-full w-full max-w-[460px] translate-x-full flex-col border-l border-[#E8E5F8] bg-white shadow-[0_30px_100px_rgba(21,19,38,0.22)] transition-transform duration-300 ease-out"
    role="dialog"
    aria-modal="true"
    aria-labelledby="tools-panel-title"
    tabindex="-1"
  >
    <div class="flex items-start justify-between border-b border-[#E8E5F8] p-6">
      <div>
        <p class="mb-2 text-xs font-extrabold uppercase tracking-[0.16em] text-[#6D5DFC]">Local tools</p>
        <h2 id="tools-panel-title" class="text-2xl font-extrabold tracking-[-0.045em] text-[#17142A]">Explore tools</h2>
        <p class="mt-2 text-sm leading-6 text-[#756F86]">Utilities powered by independent modules in <span class="font-bold text-[#17142A]">lib/tools</span>.</p>
      </div>
      <button
        type="button"
        data-tools-close
        class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[#E8E5F8] bg-[#F7F7FF] text-xl leading-none text-[#756F86] transition hover:border-[#CFC8FF] hover:text-[#6D5DFC] focus:outline-none focus:ring-4 focus:ring-[#8B7CFF]/20"
        aria-label="Close tools panel"
      >
        ×
      </button>
    </div>

    <div class="flex-1 overflow-y-auto p-6">
      <div class="mb-5 rounded-2xl border border-[#E8E5F8] bg-[#F7F7FF] p-4">
        <p class="text-sm font-bold text-[#17142A]">Open the tools workspace</p>
        <p class="mt-2 text-sm leading-6 text-[#756F86]">Each card opens <span class="font-semibold">/tools#&#123;tool.id&#125;</span> in the single-page tools hub.</p>
      </div>

      <div class="space-y-3">
        {tools.map(tool => (
          <a
            href={`/tools#${tool.id}`}
            data-tool-id={tool.id}
            class="group block w-full rounded-2xl border border-[#E8E5F8] bg-white p-4 text-left shadow-[0_12px_34px_rgba(79,65,130,0.06)] transition hover:-translate-y-0.5 hover:border-[#CFC8FF] hover:shadow-[0_18px_48px_rgba(109,93,252,0.13)] focus:outline-none focus:ring-4 focus:ring-[#8B7CFF]/20"
          >
            <span class="flex items-start gap-4">
              <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-[#6D5DFC] via-[#8B7CFF] to-[#A855F7] text-sm font-extrabold text-white shadow-[0_14px_32px_rgba(109,93,252,0.24)]">
                {tool.icon}
              </span>
              <span class="min-w-0">
                <span class="flex items-center justify-between gap-4">
                  <span class="font-extrabold tracking-[-0.03em] text-[#17142A]">{tool.name}</span>
                  <span class="rounded-full bg-[#F1EEFF] px-2.5 py-1 text-xs font-bold text-[#6D5DFC]">{tool.id}</span>
                </span>
                <span class="mt-2 block text-sm leading-6 text-[#756F86]">{tool.description}</span>
              </span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </aside>
</div>

<script is:inline>
  (() => {
    const root = document.getElementById('tools-panel-root');
    const panel = document.getElementById('tools-panel');
    const backdrop = root?.querySelector('[data-tools-backdrop]');
    const openButtons = document.querySelectorAll('[data-tools-open]');
    const closeButtons = root?.querySelectorAll('[data-tools-close]') ?? [];
    let lastFocusedElement = null;
    let isOpen = false;

    if (!root || !panel || !backdrop) return;

    const openPanel = () => {
      if (isOpen) return;
      isOpen = true;
      lastFocusedElement = document.activeElement;
      root.classList.remove('pointer-events-none');
      root.setAttribute('aria-hidden', 'false');
      document.documentElement.classList.add('overflow-hidden');

      requestAnimationFrame(() => {
        backdrop.classList.remove('bg-[#151326]/0', 'backdrop-blur-0');
        backdrop.classList.add('bg-[#151326]/30', 'backdrop-blur-sm');
        panel.classList.remove('translate-x-full');
        panel.focus({ preventScroll: true });
      });
    };

    const closePanel = () => {
      if (!isOpen) return;
      isOpen = false;
      backdrop.classList.add('bg-[#151326]/0', 'backdrop-blur-0');
      backdrop.classList.remove('bg-[#151326]/30', 'backdrop-blur-sm');
      panel.classList.add('translate-x-full');
      root.setAttribute('aria-hidden', 'true');
      document.documentElement.classList.remove('overflow-hidden');

      window.setTimeout(() => root.classList.add('pointer-events-none'), 300);
      if (lastFocusedElement instanceof HTMLElement) lastFocusedElement.focus({ preventScroll: true });
    };

    const togglePanel = () => {
      if (isOpen) closePanel();
      else openPanel();
    };

    openButtons.forEach(button => button.addEventListener('click', togglePanel));
    closeButtons.forEach(button => button.addEventListener('click', closePanel));
    backdrop.addEventListener('click', closePanel);
    document.addEventListener('keydown', event => {
      if (event.key === 'Escape' && isOpen) closePanel();
    });
  })();
</script>
