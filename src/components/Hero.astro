---
const logos = ["Notion", "Webflow", "Figma", "Framer", "Linear", "HubSpot"];
---

<section class="relative px-5 pb-32 pt-20 sm:px-8 lg:px-10 lg:pb-44 lg:pt-28">
  <div class="mx-auto max-w-5xl text-center">
    <div class="mb-7 inline-flex items-center gap-2 rounded-full border border-[#E7E4FF] bg-white/80 px-3.5 py-2 text-xs font-bold uppercase tracking-[0.16em] text-[#6D5DFC] shadow-[0_14px_40px_rgba(109,93,252,0.08)] backdrop-blur-xl">
      <span class="h-1.5 w-1.5 rounded-full bg-[#A855F7] shadow-[0_0_18px_rgba(168,85,247,0.55)]"></span>
      Curated for modern creators
    </div>

    <h1 class="mx-auto max-w-5xl text-5xl font-extrabold leading-[0.96] tracking-[-0.065em] text-[#141225] sm:text-6xl lg:text-7xl xl:text-[5.7rem]">
      Discover smarter <span class="bg-gradient-to-r from-[#6D5DFC] via-[#8B7CFF] to-[#A855F7] bg-clip-text text-transparent">tools for modern creators.</span>
    </h1>

    <p class="mx-auto mt-7 max-w-2xl text-lg leading-8 text-[#6F6A82] sm:text-xl">
      Curated AI tools, visual resources, and productivity systems designed to help creators, marketers, and builders launch cleaner workflows faster.
    </p>

    <div class="mt-10 flex flex-col justify-center gap-3 sm:flex-row">
      <button class="rounded-full bg-[#6D5DFC] px-6 py-3.5 text-sm font-bold text-white shadow-[0_18px_50px_rgba(109,93,252,0.32)] transition hover:-translate-y-0.5 hover:bg-[#5B4BEB]">
        Explore Tools
      </button>
      <button class="rounded-full border border-[#E3DFF7] bg-white px-6 py-3.5 text-sm font-bold text-[#201D35] shadow-[0_14px_36px_rgba(56,44,92,0.07)] transition hover:-translate-y-0.5 hover:border-[#CFC8FF] hover:text-[#6D5DFC]">
        See How It Works
      </button>
    </div>

    <div class="mt-7 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-[#8A849B]">
      <span>Free creator access</span>
      <span>Curated weekly</span>
      <span>No workflow clutter</span>
    </div>
  </div>

  <div class="mx-auto mt-20 max-w-7xl border-y border-[#E8E5F8] py-10">
    <div class="mb-6 text-center text-xs font-bold uppercase tracking-[0.24em] text-[#9A94AD]">Inspired by modern product teams</div>
    <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-4 text-sm font-extrabold text-[#756F86] sm:gap-x-14">
      {logos.map(logo => (
        <div class="transition hover:text-[#6D5DFC]">{logo}</div>
      ))}
    </div>
  </div>
</section>
