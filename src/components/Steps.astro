---
const steps = [
  { title: "Choose a tool", desc: "Pick from curated creator collections." },
  { title: "Add your link", desc: "Attach the source or workflow note." },
  { title: "Drive traffic", desc: "Share systems from one focused space." },
  { title: "Track & scale", desc: "Analyze, optimize, and repeat what works." }
];
---

<section id="workflow" class="px-5 py-20 sm:px-8 lg:px-10 lg:py-28">
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto mb-14 max-w-3xl text-center">
      <p class="mb-3 text-sm font-extrabold uppercase tracking-[0.16em] text-[#6D5DFC]">How it works</p>
      <h2 class="text-3xl font-extrabold tracking-[-0.055em] text-[#17142A] sm:text-5xl">Get started in four simple steps.</h2>
    </div>

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {steps.map((step, index) => (
        <div class="relative rounded-2xl border border-[#E8E5F8] bg-white p-6 shadow-[0_18px_50px_rgba(79,65,130,0.07)]">
          <div class="mb-8 flex items-center justify-between">
            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-[#F1EEFF] text-sm font-extrabold text-[#6D5DFC]">0{index + 1}</span>
            <span class="h-px flex-1 bg-gradient-to-r from-[#DCD7FF] to-transparent ml-4"></span>
          </div>
          <h3 class="text-lg font-extrabold tracking-[-0.03em] text-[#17142A]">{step.title}</h3>
          <p class="mt-3 text-sm leading-6 text-[#756F86]">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
