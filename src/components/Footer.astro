---
const product = ['Features', 'Pricing', 'Templates', 'Changelog'];
const resources = ['Documentation', 'API', 'Help center', 'Status'];
const company = ['About', 'Careers', 'Privacy', 'Terms'];
---

<footer class="px-5 pb-8 pt-20 sm:px-8 lg:px-10">
  <div class="mx-auto max-w-7xl overflow-hidden rounded-[2rem] bg-[#11101E] text-white shadow-[0_30px_90px_rgba(21,19,38,0.22)]">
    <div class="grid gap-10 border-b border-white/10 p-8 sm:p-10 lg:grid-cols-[1.2fr_1fr] lg:p-12">
      <div>
        <p class="mb-3 text-sm font-extrabold uppercase tracking-[0.16em] text-[#AFA7FF]">Ready to launch?</p>
        <h2 class="max-w-xl text-3xl font-extrabold tracking-[-0.055em] sm:text-5xl">Start building your creator system today.</h2>
        <p class="mt-5 max-w-lg text-sm leading-6 text-white/54">Join thousands of creators who use FlowPilot to discover, organize, and scale modern workflows.</p>
      </div>
      <div class="flex items-center lg:justify-end">
        <button class="rounded-full bg-white px-6 py-3.5 text-sm font-extrabold text-[#151326] shadow-[0_18px_50px_rgba(255,255,255,0.14)] transition hover:-translate-y-0.5 hover:bg-[#F1EEFF]">
          Get Started Free
        </button>
      </div>
    </div>

    <div class="grid gap-10 p-8 sm:p-10 md:grid-cols-4 lg:p-12">
      <div>
        <div class="mb-4 flex items-center gap-3">
          <span class="h-8 w-8 rounded-xl bg-gradient-to-br from-[#6D5DFC] via-[#8B7CFF] to-[#A855F7]"></span>
          <span class="font-extrabold tracking-[-0.03em]">FlowPilot</span>
        </div>
        <p class="text-sm text-white/46">© 2026 FlowPilot. All rights reserved.</p>
      </div>

      {[
        ['Product', product],
        ['Resources', resources],
        ['Company', company]
      ].map(([title, items]) => (
        <div>
          <h3 class="mb-4 text-sm font-extrabold text-white/86">{title}</h3>
          <div class="space-y-3 text-sm text-white/46">
            {items.map(item => <a href="#" class="block transition hover:text-white">{item}</a>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</footer>
