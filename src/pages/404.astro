---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ToolsPanel from "../components/ToolsPanel.astro";
import { getToolPath, toolsById } from "../../lib/tools/registry";

const popularTools = ["md5", "sha256", "base64", "json-tools", "word-counter"]
  .map((id) => toolsById[id])
  .filter(Boolean);
---

<BaseLayout
  title="Page Not Found | FlowPilot"
  description="The page you are looking for could not be found. Browse free online tools on FlowPilot."
  canonicalPath="/404"
>
  <main class="relative min-h-screen overflow-hidden bg-[#F7F7FF] text-[#151326]">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute left-1/2 top-[-24rem] h-[52rem] w-[72rem] -translate-x-1/2 rounded-full bg-[#8B7CFF]/16 blur-3xl"></div>
      <div class="absolute inset-0 bg-[linear-gradient(rgba(109,93,252,0.045)_1px,transparent_1px),linear-gradient(90deg,rgba(109,93,252,0.045)_1px,transparent_1px)] bg-[length:72px_72px]"></div>
    </div>
    <div class="relative z-10">
      <Navbar />
      <section class="px-5 py-16 sm:px-8 lg:px-10">
        <div class="mx-auto max-w-4xl text-center">
          <p class="mb-4 text-sm font-extrabold uppercase tracking-[0.16em] text-[#6D5DFC]">404</p>
          <h1 class="text-5xl font-extrabold tracking-[-0.055em] text-[#17142A] sm:text-6xl">Page not found</h1>
          <p class="mx-auto mt-5 max-w-2xl text-base leading-7 text-[#756F86]">
            The page you are looking for could not be found. You can return home or browse FlowPilot's free browser-based tools.
          </p>
          <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
            <a href="/" class="rounded-full bg-[#6D5DFC] px-6 py-3 text-sm font-extrabold text-white shadow-[0_14px_34px_rgba(109,93,252,0.24)] transition hover:-translate-y-0.5 hover:bg-[#5B4BEB]">Back home</a>
            <a href="/tools" class="rounded-full border border-[#E3DFF7] bg-white px-6 py-3 text-sm font-extrabold text-[#201D35] transition hover:border-[#CFC8FF] hover:text-[#6D5DFC]">Browse tools</a>
          </div>
          <div class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
            {popularTools.map(tool => (
              <a href={getToolPath(tool)} class="rounded-2xl border border-[#E8E5F8] bg-white/88 p-4 text-sm font-extrabold text-[#17142A] shadow-[0_12px_34px_rgba(79,65,130,0.06)] transition hover:-translate-y-0.5 hover:border-[#CFC8FF] hover:text-[#6D5DFC]">{tool.label}</a>
            ))}
          </div>
        </div>
      </section>
      <Footer />
    </div>
    <ToolsPanel />
  </main>
</BaseLayout>
