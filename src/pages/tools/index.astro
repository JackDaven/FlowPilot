---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import ToolWorkspace from "../../components/ToolWorkspace.astro";
import ToolsPanel from "../../components/ToolsPanel.astro";
import { getCategoryPath, getToolPath, toolCategories, toolsRegistry } from "../../../lib/tools/registry";
import { absoluteUrl } from "../../config/site";

const title = "Free Online Tools Directory | FlowPilot";
const description =
  "Browse free online tools for hashing, encoding, encryption, JSON formatting, URL conversion, and browser-based text utilities.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Free Online Tools Directory",
    url: absoluteUrl("/tools"),
    description
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: toolsRegistry.map((tool, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: tool.name,
      url: absoluteUrl(getToolPath(tool))
    }))
  }
];
---

<BaseLayout title={title} description={description} canonicalPath="/tools" jsonLd={jsonLd}>
  <main class="relative min-h-screen overflow-hidden bg-[#F7F7FF] text-[#151326]">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute left-1/2 top-[-24rem] h-[52rem] w-[72rem] -translate-x-1/2 rounded-full bg-[#8B7CFF]/20 blur-3xl"></div>
      <div class="absolute right-[-18rem] top-32 h-[38rem] w-[38rem] rounded-full bg-[#A855F7]/16 blur-[120px]"></div>
      <div class="absolute left-[-18rem] top-[38rem] h-[34rem] w-[34rem] rounded-full bg-[#6D5DFC]/12 blur-[120px]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(rgba(109,93,252,0.045)_1px,transparent_1px),linear-gradient(90deg,rgba(109,93,252,0.045)_1px,transparent_1px)] bg-[length:72px_72px]"></div>
    </div>

    <div class="relative z-10">
      <Navbar />

      <section class="px-5 pb-16 pt-10 sm:px-8 lg:px-10">
        <div class="mx-auto max-w-7xl">
          <nav class="mb-5 flex items-center gap-2 rounded-2xl border border-[#E8E5F8] bg-white/82 px-4 py-3 text-sm text-[#756F86] shadow-[0_12px_34px_rgba(79,65,130,0.06)] backdrop-blur-xl" aria-label="Breadcrumb">
            <a href="/" class="font-bold text-[#6D5DFC] hover:text-[#5B4BEB]">Home</a>
            <span>&gt;</span>
            <span class="font-bold text-[#17142A]">Tools</span>
          </nav>

          <div class="grid gap-8 lg:grid-cols-[1fr_0.42fr] lg:items-end">
            <div>
              <p class="mb-3 text-sm font-extrabold uppercase tracking-[0.16em] text-[#6D5DFC]">FlowPilot tools</p>
              <h1 class="max-w-4xl text-4xl font-extrabold leading-tight tracking-[-0.055em] text-[#17142A] sm:text-6xl">
                Free Online Tools Directory
              </h1>
              <p class="mt-5 max-w-2xl text-base leading-7 text-[#756F86] sm:text-lg">
                Browse free online tools for hashing, encoding, encryption, JSON formatting, URL conversion, and browser-based text utilities.
              </p>
            </div>
            <div class="rounded-[2rem] border border-[#E8E5F8] bg-white/86 p-5 text-sm leading-6 text-[#756F86] shadow-[0_18px_50px_rgba(79,65,130,0.08)] backdrop-blur-xl">
              <p class="font-extrabold text-[#17142A]">Quick tool workbench</p>
              <p class="mt-2">Open a dedicated tool page for SEO content, or use the embedded workbench below for fast hash-compatible switching.</p>
              <a href="#quick-workbench" class="mt-4 inline-flex rounded-full bg-[#6D5DFC] px-4 py-2 text-sm font-extrabold text-white shadow-[0_14px_34px_rgba(109,93,252,0.24)] transition hover:-translate-y-0.5 hover:bg-[#5B4BEB]">
                Open Workbench
              </a>
            </div>
          </div>

          <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
            {toolCategories.map(category => (
              <a href={getCategoryPath(category)} class="rounded-[2rem] border border-[#E8E5F8] bg-white/88 p-6 shadow-[0_18px_50px_rgba(79,65,130,0.08)] backdrop-blur-xl transition hover:-translate-y-1 hover:border-[#CFC8FF] hover:shadow-[0_24px_70px_rgba(109,93,252,0.14)]">
                <span class="mb-4 inline-flex rounded-full bg-[#F1EEFF] px-3 py-1 text-xs font-extrabold uppercase tracking-[0.12em] text-[#6D5DFC]">{category.tools.length} tools</span>
                <h2 class="text-xl font-extrabold tracking-[-0.035em] text-[#17142A]">{category.name}</h2>
                <p class="mt-3 text-sm leading-6 text-[#756F86]">{category.intro}</p>
              </a>
            ))}
          </div>

          <div class="mt-12 space-y-10">
            {toolCategories.map(group => (
              <section id={group.slug} class="scroll-mt-24">
                <div class="mb-4 flex items-center justify-between gap-4">
                  <div>
                    <h2 class="text-2xl font-extrabold tracking-[-0.04em] text-[#17142A]">{group.name}</h2>
                    <a href={getCategoryPath(group)} class="mt-1 inline-flex text-sm font-extrabold text-[#6D5DFC] transition hover:text-[#5B4BEB]">Open category page</a>
                  </div>
                  <span class="rounded-full bg-white/86 px-3 py-1 text-xs font-extrabold uppercase tracking-[0.12em] text-[#8A849B]">{group.tools.length} tools</span>
                </div>
                <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                  {group.tools.map(tool => (
                    <a href={getToolPath(tool)} class="group rounded-[2rem] border border-[#E8E5F8] bg-white/88 p-6 shadow-[0_18px_50px_rgba(79,65,130,0.08)] backdrop-blur-xl transition hover:-translate-y-1 hover:border-[#CFC8FF] hover:shadow-[0_24px_70px_rgba(109,93,252,0.14)]">
                      <span class="mb-4 inline-flex rounded-full bg-[#F1EEFF] px-3 py-1 text-xs font-extrabold uppercase tracking-[0.12em] text-[#6D5DFC]">{tool.label}</span>
                      <h3 class="text-xl font-extrabold tracking-[-0.035em] text-[#17142A] group-hover:text-[#6D5DFC]">{tool.name}</h3>
                      <p class="mt-3 text-sm leading-6 text-[#756F86]">{tool.intro}</p>
                      <span class="mt-5 inline-flex text-sm font-extrabold text-[#6D5DFC]">Open tool page</span>
                    </a>
                  ))}
                </div>
              </section>
            ))}
          </div>

          <section id="quick-workbench" class="mt-14 scroll-mt-24">
            <ToolWorkspace hashMode={true} />
          </section>

          <section class="mt-10 rounded-[2rem] bg-[#11101E] p-8 text-white shadow-[0_30px_90px_rgba(21,19,38,0.22)] sm:p-10">
            <h2 class="text-3xl font-extrabold tracking-[-0.055em]">Browser-first utility discovery</h2>
            <div class="mt-5 grid gap-4 text-sm leading-6 text-white/64 md:grid-cols-3">
              <p>FlowPilot tools run in the browser when possible.</p>
              <p>Many tools do not require uploading data to a server.</p>
              <p>Related tools are grouped for faster discovery.</p>
            </div>
          </section>
        </div>
      </section>

      <Footer />
    </div>

    <ToolsPanel />
  </main>
</BaseLayout>
